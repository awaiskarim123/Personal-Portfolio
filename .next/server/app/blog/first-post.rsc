12:[["$","p",null,{"className":"mt-4 text-muted-foreground leading-7","children":"Next.js 15 brings a more stable App Router and improved server components. Here's what matters for building fast sites."}],"\n",["$","h2",null,{"className":"mt-8 text-2xl font-bold text-foreground","children":"App Router"}],"\n",["$","p",null,{"className":"mt-4 text-muted-foreground leading-7","children":"The App Router uses a file-system based routing. Each folder represents a route segment. Layouts wrap child segments and persist across navigations."}],"\n",["$","h2",null,{"className":"mt-8 text-2xl font-bold text-foreground","children":"Server Components"}],"\n",["$","p",null,{"className":"mt-4 text-muted-foreground leading-7","children":["By default, components in the App Router are ",["$","strong",null,{"children":"React Server Components"}],". They run only on the server, so you can fetch data and access backends without exposing secrets to the client."]}],"\n",["$","ul",null,{"className":"mt-4 list-disc space-y-2 pl-6 text-muted-foreground","children":["\n",["$","li",null,{"children":["No ",["$","code",null,{"className":"rounded bg-muted px-1.5 py-0.5 font-mono text-sm","children":"useState"}]," or ",["$","code",null,{"className":"rounded bg-muted px-1.5 py-0.5 font-mono text-sm","children":"useEffect"}]," in server components."]}],"\n",["$","li",null,{"children":"Use async/await directly in the component."}],"\n",["$","li",null,{"children":"Pass serializable props to client components."}],"\n"]}],"\n",["$","h2",null,{"className":"mt-8 text-2xl font-bold text-foreground","children":"Client Components"}],"\n",["$","p",null,{"className":"mt-4 text-muted-foreground leading-7","children":["Add ",["$","code",null,{"className":"rounded bg-muted px-1.5 py-0.5 font-mono text-sm","children":"\"use client\""}]," at the top when you need interactivity: hooks, event handlers, or browser APIs. Keep the client boundary as low as possible for better performance."]}],"\n",["$","p",null,{"className":"mt-4 text-muted-foreground leading-7","children":"You're now ready to build with Next.js 15."}]]
