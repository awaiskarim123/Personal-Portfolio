border-t border-border/40 bg-background","children":["$","div",null,{"className":"mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8","children":["$","div",null,{"className":"flex flex-col items-center justify-between gap-6 sm:flex-row","children":[["$","p",null,{"className":"text-sm text-muted-foreground","children":["© ",2026," Portfolio. Built with Next.js."]}],["$","nav",null,{"className":"flex flex-wrap justify-center gap-6","children":[["$","$L5","/blog",{"href":"/blog","className":"text-sm text-muted-foreground transition-colors hover:text-foreground","children":"Blog"}],["$","$L5","/system-design",{"href":"/system-design","className":"text-sm text-muted-foreground transition-colors hover:text-foreground","children":"System Design"}],["$","$L5","/projects",{"href":"/projects","className":"text-sm text-muted-foreground transition-colors hover:text-foreground","children":"Projects"}],["$","$L5","/contact",{"href":"/contact","className":"text-sm text-muted-foreground transition-colors hover:text-foreground","children":"Contact"}]]}]]}]}]}]]}]}]]}],{"children":["blog",["$","$1","c",{"children":[null,["$","$L3",null,{"parallelRouterKey":"children","error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L4",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","forbidden":"$undefined","unauthorized":"$undefined"}]]}],{"children":["__PAGE__",["$","$1","c",{"children":[["$","div",null,{"className":"mx-auto max-w-4xl px-4 py-16 sm:px-6 sm:py-24 lg:px-8","children":[["$","div",null,{"children":[["$","h1",null,{"className":"text-4xl font-bold tracking-tight text-foreground sm:text-5xl","children":"Blog"}],["$","p",null,{"className":"mt-4 text-lg text-muted-foreground","children":"Notes, tutorials, and thoughts on building software."}]]}],["$","$6",null,{"fallback":["$","div",null,{"className":"mt-10 animate-pulse space-y-8","children":[["$","div","1",{"className":"h-32 rounded-xl bg-muted"}],["$","div","2",{"className":"h-32 rounded-xl bg-muted"}],["$","div","3",{"className":"h-32 rounded-xl bg-muted"}]]}],"children":["$","$L7",null,{"posts":[{"slug":"performance-tips","title":"Web Performance Tips That Actually Work","description":"Practical steps to make your web app feel faster.","publishedAt":"2025-02-01","tags":["performance","frontend","web"],"readingTime":"1 min read","content":"\nPerformance is a feature. Here are a few changes that tend to move the needle.\n\n## 1. Optimize Images\n\nUse the right format (WebP/AVIF when supported) and size. Next.js `Image` does a lot of this for you: lazy loading, responsive `srcset`, and placeholders.\n\n## 2. Reduce JavaScript\n\nShip less JS. Prefer server components so that only interactive parts load on the client. Code-split routes and heavy libraries.\n\n## 3. Cache Wisely\n\nSet cache headers for static assets. Use `stale-while-revalidate` for data that can be a bit stale. For static sites, SSG gives you a fast first load.\n\n## 4. Measure\n\nUse Core Web Vitals (LCP, FID, CLS) and real-user metrics. Optimize what you measure; otherwise you're guessing.\n\nStart with one of these and measure again.\n"},{"slug":"first-post","title":"Getting Started with Next.js 15","description":"A quick overview of the App Router and server components in Next.js 15.","publishedAt":"2025-01-15","tags":["nextjs","react","frontend"],"readingTime":"1 min read","content":"\nNext.js 15 brings a more stable App Router and improved server components. Here's what matters for building fast sites.\n\n## App Router\n\nThe App Router uses a file-system based routing. Each folder represents a route segment. Layouts wrap child segments and persist across navigations.\n\n## Server Components\n\nBy default, components in the App Router are **React Server Components**. They run only on the server, so you can fetch data and access backends without exposing secrets to the client.\n\n- No `useState` or `useEffect` in server components.\n- Use async/await directly in the component.\n- Pass serializable props to client components.\n\n## Client Components\n\nAdd `\"use client\"` at the top when you need interactivity: hooks, event handlers, or browser APIs. Keep the client boundary as low as possible for better performance.\n\nYou're now ready to build with Next.js 15.\n"}],"allTags":["frontend","nextjs","performance","react","web"]}]}]]}],null,"$L8"]}],{},null,false]},null,false]},null,false],"$L9",false]],"m":"$undefined","G":["$a",[]],"s":false,"S":true}
