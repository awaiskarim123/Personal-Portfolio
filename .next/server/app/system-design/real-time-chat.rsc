12:[["$","p",null,{"className":"mt-4 text-muted-foreground leading-7","children":"Real-time chat requires low latency and reliable delivery. Here's a high-level architecture that scales."}],"\n",["$","h2",null,{"className":"mt-8 text-2xl font-bold text-foreground","children":"Components"}],"\n",["$","ol",null,{"className":"mt-4 list-decimal space-y-2 pl-6 text-muted-foreground","children":["\n",["$","li",null,{"children":[["$","strong",null,{"children":"Clients"}]," – Web or mobile apps that connect via WebSockets (or long polling as fallback)."]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":"WebSocket server"}]," – Maintains persistent connections and pushes messages. Can be scaled horizontally with a sticky session or a shared pub/sub layer."]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":"Message queue"}]," – e.g. Redis Pub/Sub or Kafka. When a user sends a message, the API publishes it; all servers subscribed to the room forward it to their connected clients."]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":"API server"}]," – Handles REST/GraphQL for history, auth, and metadata. Writes messages to the queue and optionally to a database for persistence."]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":"Database"}]," – Stores message history and room/user data. Use read replicas if you need to scale reads."]}],"\n"]}],"\n",["$","h2",null,{"className":"mt-8 text-2xl font-bold text-foreground","children":"Flow"}],"\n",["$","ul",null,{"className":"mt-4 list-disc space-y-2 pl-6 text-muted-foreground","children":["\n",["$","li",null,{"children":["User A sends a message → API validates and publishes to the queue (e.g. channel ",["$","code",null,{"className":"rounded bg-muted px-1.5 py-0.5 font-mono text-sm","children":"room:123"}],")."]}],"\n",["$","li",null,{"children":["All WebSocket servers subscribed to ",["$","code",null,{"className":"rounded bg-muted px-1.5 py-0.5 font-mono text-sm","children":"room:123"}]," receive the message and push to their connected clients (User B, User C, …)."]}],"\n",["$","li",null,{"children":"Message can also be written to the DB for history."}],"\n"]}],"\n",["$","h2",null,{"className":"mt-8 text-2xl font-bold text-foreground","children":"Considerations"}],"\n",["$","ul",null,{"className":"mt-4 list-disc space-y-2 pl-6 text-muted-foreground","children":["\n",["$","li",null,{"children":[["$","strong",null,{"children":"Presence"}]," – Track who's online via a Redis set or similar; broadcast join/leave on the room channel."]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":"History"}]," – On connect, fetch last N messages from the API; optionally use cursor-based pagination."]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":"Scale"}]," – Add more WebSocket servers behind a load balancer; they share state only via the message queue and Redis."]}],"\n"]}],"\n",["$","p",null,{"className":"mt-4 text-muted-foreground leading-7","children":"This pattern keeps the system simple and scalable for most chat use cases."}]]
