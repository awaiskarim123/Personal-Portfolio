12:[["$","p",null,{"className":"mt-4 text-muted-foreground leading-7","children":"Redis is often used as a cache in front of a database or external API. A few patterns make it effective."}],"\n",["$","h2",null,{"className":"mt-8 text-2xl font-bold text-foreground","children":"Cache-Aside (Lazy Loading)"}],"\n",["$","ol",null,{"className":"mt-4 list-decimal space-y-2 pl-6 text-muted-foreground","children":["\n",["$","li",null,{"children":"App reads from Redis."}],"\n",["$","li",null,{"children":"On miss, read from DB (or API), then write to Redis."}],"\n",["$","li",null,{"children":"App returns the value."}],"\n"]}],"\n",["$","p",null,{"className":"mt-4 text-muted-foreground leading-7","children":[["$","strong",null,{"children":"Pros:"}]," Only popular data gets cached. ",["$","strong",null,{"children":"Cons:"}]," First request per key is slow; you can get thundering herd if many requests miss at once (use a lock or single-flight)."]}],"\n",["$","h2",null,{"className":"mt-8 text-2xl font-bold text-foreground","children":"TTL and Invalidation"}],"\n",["$","ul",null,{"className":"mt-4 list-disc space-y-2 pl-6 text-muted-foreground","children":["\n",["$","li",null,{"children":["Set a TTL on every key so stale data eventually disappears. e.g. ",["$","code",null,{"className":"rounded bg-muted px-1.5 py-0.5 font-mono text-sm","children":"SET key value EX 3600"}],"."]}],"\n",["$","li",null,{"children":"For invalidation: delete the key when the source data changes, or use a short TTL and accept eventual consistency."}],"\n"]}],"\n",["$","h2",null,{"className":"mt-8 text-2xl font-bold text-foreground","children":"Key Design"}],"\n",["$","ul",null,{"className":"mt-4 list-disc space-y-2 pl-6 text-muted-foreground","children":["\n",["$","li",null,{"children":["Use a clear namespace: ",["$","code",null,{"className":"rounded bg-muted px-1.5 py-0.5 font-mono text-sm","children":"app:entity:id"}]," e.g. ",["$","code",null,{"className":"rounded bg-muted px-1.5 py-0.5 font-mono text-sm","children":"blog:post:123"}],"."]}],"\n",["$","li",null,{"children":"Keep keys small but unique. Hash long IDs if needed."}],"\n",["$","li",null,{"children":"Avoid huge values; split into smaller chunks if necessary."}],"\n"]}],"\n",["$","h2",null,{"className":"mt-8 text-2xl font-bold text-foreground","children":"Connection and Pooling"}],"\n",["$","p",null,{"className":"mt-4 text-muted-foreground leading-7","children":"Use a connection pool so you don't open a new connection per request. Most Redis clients support pooling. Run Redis close to the app to reduce latency."}],"\n",["$","h2",null,{"className":"mt-8 text-2xl font-bold text-foreground","children":"When Not to Cache"}],"\n",["$","ul",null,{"className":"mt-4 list-disc space-y-2 pl-6 text-muted-foreground","children":["\n",["$","li",null,{"children":"Data that changes very frequently and is read rarely."}],"\n",["$","li",null,{"children":"Data that must always be fresh (use short TTL or no cache)."}],"\n",["$","li",null,{"children":"Very large objects that evict more useful entries."}],"\n"]}],"\n",["$","p",null,{"className":"mt-4 text-muted-foreground leading-7","children":"Start with cache-aside, set TTLs, and add invalidation where you need stronger consistency."}]]
