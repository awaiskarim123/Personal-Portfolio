12:[["$","p",null,{"className":"mt-4 text-muted-foreground leading-7","children":"Rate limiting protects your API from abuse and keeps traffic predictable. Here are common approaches."}],"\n",["$","h2",null,{"className":"mt-8 text-2xl font-bold text-foreground","children":"Why Rate Limit?"}],"\n",["$","ul",null,{"className":"mt-4 list-disc space-y-2 pl-6 text-muted-foreground","children":["\n",["$","li",null,{"children":"Prevent a single client from consuming all capacity."}],"\n",["$","li",null,{"children":"Encourage fair use and allow you to tier by plan."}],"\n",["$","li",null,{"children":"Mitigate some DoS and brute-force attacks."}],"\n"]}],"\n",["$","h2",null,{"className":"mt-8 text-2xl font-bold text-foreground","children":"Algorithms"}],"\n",["$","p",null,{"className":"mt-4 text-muted-foreground leading-7","children":[["$","strong",null,{"children":"Fixed window"}]," – Count requests per time window (e.g. 100 per minute). Simple but can allow bursts at window boundaries."]}],"\n",["$","p",null,{"className":"mt-4 text-muted-foreground leading-7","children":[["$","strong",null,{"children":"Sliding window"}]," – Count over a rolling window. Fairer but needs more state (e.g. store timestamps or use a weighted average)."]}],"\n",["$","p",null,{"className":"mt-4 text-muted-foreground leading-7","children":[["$","strong",null,{"children":"Token bucket"}]," – Refill tokens at a rate; each request consumes one. Allows short bursts up to bucket size."]}],"\n",["$","p",null,{"className":"mt-4 text-muted-foreground leading-7","children":[["$","strong",null,{"children":"Leaky bucket"}]," – Requests are processed at a constant rate. Smooths traffic but can increase latency."]}],"\n",["$","h2",null,{"className":"mt-8 text-2xl font-bold text-foreground","children":"Implementation with Redis"}],"\n",["$","p",null,{"className":"mt-4 text-muted-foreground leading-7","children":"Use Redis to store counters or token buckets keyed by client (API key, IP, or user id):"}],"\n",["$","ul",null,{"className":"mt-4 list-disc space-y-2 pl-6 text-muted-foreground","children":["\n",["$","li",null,{"children":[["$","strong",null,{"children":"INCR"}]," + ",["$","strong",null,{"children":"EXPIRE"}]," for fixed window."]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":"Sorted set"}]," of request timestamps for sliding window (add current time, remove older than window, count)."]}],"\n",["$","li",null,{"children":"Lua scripts for atomic token-bucket updates."}],"\n"]}],"\n",["$","p",null,{"className":"mt-4 text-muted-foreground leading-7","children":["Example key: ",["$","code",null,{"className":"rounded bg-muted px-1.5 py-0.5 font-mono text-sm","children":"ratelimit:{client_id}:{window}"}],". Set TTL to the window length so keys expire."]}],"\n",["$","h2",null,{"className":"mt-8 text-2xl font-bold text-foreground","children":"Response Headers"}],"\n",["$","p",null,{"className":"mt-4 text-muted-foreground leading-7","children":"Return standard headers so clients can back off:"}],"\n",["$","ul",null,{"className":"mt-4 list-disc space-y-2 pl-6 text-muted-foreground","children":["\n",["$","li",null,{"children":[["$","code",null,{"className":"rounded bg-muted px-1.5 py-0.5 font-mono text-sm","children":"X-RateLimit-Limit"}]," – max requests per window"]}],"\n",["$","li",null,{"children":[["$","code",null,{"className":"rounded bg-muted px-1.5 py-0.5 font-mono text-sm","children":"X-RateLimit-Remaining"}]," – remaining in current window"]}],"\n",["$","li",null,{"children":[["$","code",null,{"className":"rounded bg-muted px-1.5 py-0.5 font-mono text-sm","children":"Retry-After"}]," – when to retry (on 429)"]}],"\n"]}],"\n",["$","p",null,{"className":"mt-4 text-muted-foreground leading-7","children":"Combine rate limiting with auth and monitoring for a solid API."}]]
